rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Issue photos — authenticated users upload to their own folder
    match /issues/{userId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Officer after-photos (Phase 4)
    match /resolutions/{issueId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
